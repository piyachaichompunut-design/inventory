{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/rpc.js": { "maxDuration": 30 },
    "api/telegram.js": { "maxDuration": 30 },
    "api/line.js": { "maxDuration": 30 },
    "api/odoo-image.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron", "schedule": "45 0 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
